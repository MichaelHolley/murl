# Copy to .env, then run: docker compose up -d --build

# --- Postgres ---------------------------------------------------------------
# A literal $ in the password must be escaped as $$ — Compose interpolates this file.
POSTGRES_USER=murl
POSTGRES_PASSWORD=change-me
POSTGRES_DB=murl

# DATABASE_URL is intentionally absent: docker-compose.yml builds it from the
# three values above and points it at the internal `postgres` host.

# --- Published ports (host side) --------------------------------------------
SERVICE_PORT=3000
WEB_PORT=4000

# --- Service ----------------------------------------------------------------
# Auth is on unless this is exactly "false". When on, API_TOKEN is required or
# the service exits on boot.
API_TOKEN_MIDDLEWARE_ENABLED=true
API_TOKEN=change-me

# Origin short links are rendered with — must be the host-visible service URL,
# i.e. match SERVICE_PORT, or every generated link 404s.
BASE_URL=http://localhost:3000

# CORS allowlist — must be the host-visible *web client* origin, i.e. match
# WEB_PORT. No trailing slash, no path. Required; the service exits if unset.
ALLOWED_ORIGIN=http://localhost:4000

# --- Web client (build time only) -------------------------------------------
# Baked into the JS bundle. Must be the host-visible service URL (the browser
# runs outside the Compose network and cannot resolve `service`).
# Changing this requires: docker compose build web-client
VITE_SERVICE_URL=http://localhost:3000
