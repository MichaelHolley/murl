{
  "name": "murl",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:service": "turbo run dev --filter=murl-service",
    "dev:web": "turbo run dev --filter=murl-web-client",
    "dev:cli": "bun run --cwd packages/cli-client index.ts",
    "config:cli": "bun run --cwd packages/cli-client config.ts",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fmt": "turbo run fmt"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "turbo": "^2.8.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
